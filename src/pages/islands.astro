---
import Layout from '../layouts/Layout.astro';
import InteractiveCounter from '../components/InteractiveCounter.jsx';
import PageLoadTimer from '../components/PageLoadTimer.jsx';
---

<Layout title="Islands Architecture">
  <section class="section" style="padding-top: 7rem;">
    <div class="container">
      <div class="section-title">
        <h2>Islands Architecture Demo</h2>
        <p>
          Bagian <span style="color: var(--green);">hijau</span> = HTML statis (zero JS).
          Bagian <span style="color: var(--accent-light);">ungu</span> = interactive island (ada JS).
        </p>
      </div>

      <!-- Static content - ZERO JS -->
      <div class="island island-static" style="margin-bottom: 2rem;">
        <div class="island-label">Static HTML - 0KB JS</div>
        <h3 style="margin-bottom: 1rem;">Konten Ini 100% HTML Statis</h3>
        <p style="color: var(--text-secondary); line-height: 1.8;">
          Teks yang Anda baca ini tidak memiliki JavaScript sama sekali.
          Browser langsung merender-nya sebagai HTML. Tidak ada hydration, tidak ada virtual DOM,
          tidak ada framework runtime. Inilah mengapa Astro begitu cepat &mdash;
          konten statis tidak perlu JavaScript.
        </p>
        <ul style="color: var(--text-secondary); margin-top: 1rem; padding-left: 1.5rem; line-height: 2;">
          <li>Render instan oleh browser</li>
          <li>Tidak ada delay hydration</li>
          <li>CSS sudah di-inline</li>
          <li>SEO-friendly (crawlable HTML)</li>
        </ul>
      </div>

      <!-- Interactive island - HAS JS -->
      <div class="island" style="margin-bottom: 2rem;">
        <div class="island-label">Interactive Island - JS Aktif</div>
        <InteractiveCounter client:visible label="&#9889; Counter (client:visible)" />
        <p style="text-align: center; color: var(--text-secondary); font-size: 0.8rem; margin-top: 1rem;">
          Komponen ini hanya load JavaScript saat terlihat di viewport (client:visible).
          Scroll ke sini = JS mulai hydrate.
        </p>
      </div>

      <!-- Hydration timer island -->
      <div class="island" style="margin-bottom: 2rem;">
        <div class="island-label">Hydration Timer - JS Aktif</div>
        <PageLoadTimer client:load />
      </div>

      <!-- More static content -->
      <div class="island island-static" style="margin-bottom: 2rem;">
        <div class="island-label">Static HTML - 0KB JS</div>
        <h3 style="margin-bottom: 1rem;">Strategi Hydration di Astro</h3>
        <div class="code-block" style="margin-top: 1rem;">
          <span class="comment">&lt;!-- Load segera --&gt;</span><br />
          &lt;<span class="tag">Counter</span> <span class="attr">client:load</span> /&gt;<br /><br />

          <span class="comment">&lt;!-- Load saat terlihat di viewport --&gt;</span><br />
          &lt;<span class="tag">Counter</span> <span class="attr">client:visible</span> /&gt;<br /><br />

          <span class="comment">&lt;!-- Load saat browser idle --&gt;</span><br />
          &lt;<span class="tag">Chat</span> <span class="attr">client:idle</span> /&gt;<br /><br />

          <span class="comment">&lt;!-- Load hanya di client (no SSR) --&gt;</span><br />
          &lt;<span class="tag">Map</span> <span class="attr">client:only</span> <span class="attr">="preact"</span> /&gt;<br /><br />

          <span class="comment">&lt;!-- Tidak ada directive = TIDAK ADA JS --&gt;</span><br />
          &lt;<span class="tag">Header</span> /&gt; <span class="comment">&lt;!-- HTML murni! --&gt;</span>
        </div>
      </div>

      <!-- Second interactive counter with different strategy -->
      <div class="island" style="margin-bottom: 2rem;">
        <div class="island-label">Interactive Island - JS Aktif (client:idle)</div>
        <InteractiveCounter client:idle label="&#9203; Counter (client:idle)" />
        <p style="text-align: center; color: var(--text-secondary); font-size: 0.8rem; margin-top: 1rem;">
          Komponen ini load JavaScript saat browser idle &mdash; tidak mengganggu render utama.
        </p>
      </div>

      <div style="text-align: center; margin-top: 2rem;">
        <p style="color: var(--text-secondary); margin-bottom: 1.5rem;">
          Buka DevTools &rarr; Network tab untuk melihat bahwa hanya island components yang mengirim file JS.
        </p>
        <a href="/benchmark" class="btn btn-primary">Lihat Benchmark &#8594;</a>
        <a href="/about" class="btn btn-outline" style="margin-left: 0.5rem;">About &#8594;</a>
      </div>
    </div>
  </section>
</Layout>
